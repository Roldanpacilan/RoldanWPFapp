<Window x:Class="RoldanWPFapp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 Music List" Height="500" Width="900"
        Background="#FFF7F3E9">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Background="White" CornerRadius="20" Padding="15" Margin="5" Grid.Column="0" 
               
                />
        <StackPanel>

            <!-- TITLE -->
            <TextBlock Text="🎶 My Music Collection"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

            <Separator Margin="0,5"/>

            <!-- DATA GRID -->
            <DataGrid x:Name="dataGrid" Height="280"
                          AutoGenerateColumns="False"
                          SelectionChanged="dataGrid_SelectionChanged"
                          FontSize="14"
                          Background="#FFFDFDFD"
                          RowBackground="#FFF9F9F9"
                          AlternatingRowBackground="#FFF1F1F1"
                          BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="👤 Name"
                            Binding="{Binding Firstname}" Width="*"/>
                    <DataGridTextColumn Header="🎵 Song Title"
                            Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- DELETE BUTTON -->
            <Button x:Name="btnDeleteData" Content="🗑 Delete"
                        Height="45" FontSize="16"
                        FontWeight="SemiBold"
                        Margin="0,10,0,0"
                        IsEnabled="False"
                        Click="btnDeleteData_Click"
                        Background="#FFE57373"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
        </StackPanel>


        <!-- RIGHT PANEL -->
        <Border Background="White" CornerRadius="20" Padding="15" Margin="5" Grid.Column="1">
            <StackPanel>

                <!-- FORM TITLE -->
                <TextBlock Text="✨ Add Music"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- NAME -->
                <TextBlock Text="Name" FontWeight="SemiBold"/>
                <TextBox x:Name="txtFullname"
                         Height="30"
                         Margin="0,5,0,10"
                         Padding="5"
                         BorderBrush="#FFBDBDBD"
                         TextChanged="txtFullname_TextChanged"/>

                <!-- SONG TITLE -->
                <TextBlock Text="Song Title" FontWeight="SemiBold"/>
                <TextBox x:Name="txtAddress"
                         Height="30"
                         Margin="0,5,0,15"
                         Padding="5"
                         BorderBrush="#FFBDBDBD"/>

                <!-- SAVE BUTTON -->
                <Button x:Name="btnSave"
                        Content="💾 Save"
                        Height="45"
                        FontSize="16"
                        FontWeight="Bold"
                        Click="btnSave_Click"
                        Background="#FF81C784"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
